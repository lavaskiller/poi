    "union-city":   { "label": "우혁 개인블로그",  "color": "cyan",   "owner": "우혁",    "source_type": "personal-blog",    "default_confidence": "confirmed_user", "desc": "우혁의 Union City 여행 블로그." },
    "vancouver":    { "label": "인소 개인블로그",  "color": "violet", "owner": "인소",    "source_type": "personal-blog",    "default_confidence": "confirmed_user", "desc": "인소의 Vancouver 여행 블로그." }
